# Aible fork of the OpenShell supervisor image.
#
# The supervisor carries the `openshell-sandbox` binary, which the
# agent-sandbox-controller copies into every sandbox pod via an init container.
# Inside the sandbox the binary acts as PID 1: process supervision, policy
# enforcement, SSH server, and gRPC callback to the gateway.
#
# The gateway and supervisor must be compiled from the same source tree so
# their protobuf schemas stay in sync.
#
# Build:
#   IMAGE_TAG=20260521 tasks/scripts/docker-build-local.sh supervisor
#
# Unlike the gateway, the upstream supervisor image is FROM scratch (statically
# linked). Our cargo build produces a dynamically linked binary that needs
# glibc + ld-linux at runtime, so we use debian-slim as the final base.
ARG BASE_IMAGE=debian:trixie-slim

# ---------------------------------------------------------------------------
# Stage 1: Compile sandbox binary from source
# ---------------------------------------------------------------------------
FROM rust:1.95.0-slim-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    pkg-config \
    libssl-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
COPY proto/ proto/
COPY providers/ providers/

RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/build/target \
    cargo build --release \
        --features "openshell-core/dev-settings" \
        --bin openshell-sandbox \
    && mkdir -p /out \
    && install -m 0755 target/release/openshell-sandbox /out/openshell-sandbox

# ---------------------------------------------------------------------------
# Stage 2: Layer compiled binary onto the base image
# ---------------------------------------------------------------------------
FROM ${BASE_IMAGE}

# Match the upstream image's binary path and entrypoint so the inner chart's
# supervisor.image reference works without changes.
COPY --from=builder /out/openshell-sandbox /openshell-sandbox
ENTRYPOINT ["/openshell-sandbox"]
